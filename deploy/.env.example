# Commit refs to pin (leave as 'main' to track latest)
CLK_REF=main
AUTOGUI_REF=main
OSSO_REF=main

# OpenWebUI (assumed running externally)
OPENWEBUI_BASE_URL=http://your-openwebui-host:3000
OPENWEBUI_API_KEY=sk-your-key-here
OPENWEBUI_MODEL=llama3.1:70b

# Service URLs for real use (host processes)
# When running AutoGUI and OSScreenObserver on the host:
AUTOGUI_BASE_URL=http://host.docker.internal:8002
OSSO_BASE_URL=http://host.docker.internal:5001

# CLK runs in a container by default:
CLK_BASE_URL=http://clk:8001

# Paths (relative to this file's directory)
CLK_WORKSPACES_DIR=./data/clk-workspaces
