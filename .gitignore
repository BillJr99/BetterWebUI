# Python virtualenv (created by start.sh / start.bat on first run)
.venv/
__pycache__/
*.pyc
*.pyo
*.pyd
*.egg-info/

# User data — settings (with API key), conversations, uploaded files, etc.
# These are personal to each install and should never be committed.
data/config.json
data/conversations.json
data/workspaces.json
data/mcp_servers.json
data/cli_tools.json
data/system_prompts.json
data/uploads/
data/generated/
data/scheduled_tasks.json
data/checkpoints/
data/verification/
data/branding.json
data/oauth/

# OS / editor cruft
.DS_Store
Thumbs.db
.idea/
.vscode/
*.swp
*~

# Logs / runtime
*.log
logs/

# Local workspace folder (Docker volume mount point; gitignore so user files aren't committed)
workspace/

# Playwright test artifacts (installed/generated locally)
tests/playwright/node_modules/
tests/playwright/ui-report/
tests/playwright/playwright-report/
tests/playwright/test-results/

# OpenWebUI auto-generated secret key (created at startup; never commit)
.webui_secret_key

# Runtime env file written by the wizard / CI (contains API keys)
deploy/.env
